{
  "expo": {
    "name": "Caller",
    "slug": "caller",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vivtej.telecrm"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.jpg",
        "backgroundColor": "#ffffff"
      },
      "package": "com.vivtej.telecrm",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "SCHEDULE_EXACT_ALARM",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "READ_CALL_LOG"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.jpg"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "./plugins/withCallLogPermissions",
      "./plugins/withFirebaseConfig",
      "./plugins/withCallModule"
    ]
  }
}
