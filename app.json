{
  "expo": {
    "name": "Vivtej TeleCRM",
    "slug": "vivtej-telecrm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app_logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vivtej.telecrm"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app_logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.vivtej.telecrm",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "SCHEDULE_EXACT_ALARM",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "READ_CALL_LOG",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "FOREGROUND_SERVICE",
        "READ_PHONE_STATE",
        "FOREGROUND_SERVICE_DATA_SYNC"
      ]
    },
    "web": {
      "favicon": "./assets/app_logo.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "./plugins/withCallLogPermissions",
      "./plugins/withFirebaseConfig",
      "./plugins/withCallModule",
      [
        "expo-file-system",
        {
          "shouldHandleManagedDownloads": true
        }
      ],
      "./plugins/withPhoneStateReceiver",
      "./plugins/withSigningConfig"
    ]
  }
}
